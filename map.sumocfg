<configuration>
    <input>
        <net-file value="map.net.xml"/>
        <route-files value="routes.rou.xml"/>
    </input>

    <processing>
        <time-to-teleport value="-1"/>
    </processing>

    <time>
        <begin value="0"/>
        <end value="3600"/>
    </time>

    <output>
        <fcd-output value="mobility_trace.xml"/>
    </output>
</configuration>
